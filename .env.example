# Tavily — sign up at https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Notion — create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxx

# The ID of the Notion page where weekly reports will be created as sub-pages.
# To find it: open the page in Notion, click "..." > "Copy link".
# The page ID is the 32-char hex string in the URL (add dashes to make a UUID).
# Example: https://notion.so/My-Page-abc123def456... → abc123def456...
NOTION_PARENT_PAGE_ID=your-page-id-here
